# API Keys (all optional — dreakon degrades gracefully without them)
SHODAN_API_KEY=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
GITHUB_TOKEN=
URLSCAN_API_KEY=

# Concurrency tuning
DNS_CONCURRENCY=500
HTTP_CONCURRENCY=50
CRAWL_CONCURRENCY=10
FUZZ_CONCURRENCY=5

# Timeouts (seconds)
HTTP_TIMEOUT=10
DNS_TIMEOUT=5

# Crawl depth limit
MAX_CRAWL_DEPTH=5
